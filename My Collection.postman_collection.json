    {
      "name": "GET user account detail by email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Final API Check\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    var code = jsonData.responseCode;\r",
              "    pm.expect(code).to.be.oneOf([200, 404]);\r",
              "\r",
              "    if (code === 200) {\r",
              "        pm.expect(jsonData.user).to.have.property('name');\r",
              "    } else {\r",
              "        // Мы используем .include вместо .equal, чтобы не придираться к мелочам\r",
              "        pm.expect(jsonData.message).to.include(\"Account not found\");\r",
              "    }\r",
              "});"
            ],
